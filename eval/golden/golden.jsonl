// Golden set v1 — authored for agentic-rag, grounded in the committed corpus.
// Every `locator` is a verbatim substring of its source document (verified by
// scripts/verify_golden.py). Questions are paraphrased, never lifted from chunk
// text (enforced by the n-gram leakage check in eval/materialize.py).
// qtypes: factoid | how-to | multi-hop | vocab-mismatch | negative-control
// grades: primary (directly answers) | supporting (needed context)
{"qid": "q001", "question": "In pgvector, what is the default size of the dynamic candidate list used during an HNSW search?", "expected_answer": "40. The search-time dynamic candidate list `hnsw.ef_search` defaults to 40.", "qtype": "factoid", "gold": [{"doc_id": "pgvector/README", "locator": "40 by default", "grade": "primary"}], "notes": "Failure-1 case: exact identifier hnsw.ef_search, dense retrieval blurs it."}
{"qid": "q002", "question": "What HNSW build parameters does pgvector's example CREATE INDEX use, and what does each control?", "expected_answer": "m = 16 (max connections per layer) and ef_construction = 64 (size of the dynamic candidate list while building the graph).", "qtype": "factoid", "gold": [{"doc_id": "pgvector/README", "locator": "m = 16, ef_construction = 64", "grade": "primary"}, {"doc_id": "pgvector/README", "locator": "64 by default", "grade": "supporting"}]}
{"qid": "q003", "question": "How do I trade a slower index build for better recall when creating an HNSW index in pgvector?", "expected_answer": "Raise ef_construction: a higher value gives better recall at the cost of index build/insert speed.", "qtype": "how-to", "gold": [{"doc_id": "pgvector/README", "locator": "better recall at the cost of index build time", "grade": "primary"}]}
{"qid": "q004", "question": "Which distance operator does pgvector provide for cosine distance?", "expected_answer": "The `<=>` operator computes cosine distance.", "qtype": "factoid", "gold": [{"doc_id": "pgvector/README", "locator": "cosine distance (`<=>`)", "grade": "primary"}]}
{"qid": "q005", "question": "My approximate vector search sometimes returns fewer rows than the LIMIT I asked for. Why does that happen with pgvector?", "expected_answer": "Results are bounded by the dynamic candidate list size (hnsw.ef_search, default 40); fewer rows can come back due to that limit, dead tuples, or filtering. Enable iterative index scans to fetch more.", "qtype": "vocab-mismatch", "gold": [{"doc_id": "pgvector/README", "locator": "limited by the size of the dynamic candidate list", "grade": "primary"}]}
{"qid": "q006", "question": "How can I force pgvector to use exact nearest-neighbor search instead of the approximate index for one query?", "expected_answer": "Disable index scans in the transaction, e.g. SET LOCAL enable_indexscan = off, so the query does an exact scan.", "qtype": "how-to", "gold": [{"doc_id": "pgvector/README", "locator": "enable_indexscan = off", "grade": "primary"}]}
{"qid": "q016", "question": "Which index type does PostgreSQL create by default when you run CREATE INDEX without specifying one?", "expected_answer": "B-tree. CREATE INDEX creates B-tree indexes by default.", "qtype": "factoid", "gold": [{"doc_id": "postgres/indexes-types", "locator": "creates B-tree indexes, which fit the most common situations", "grade": "primary"}]}
{"qid": "q017", "question": "My table keeps growing on disk even though I delete rows from it every day. How do I reclaim that space in PostgreSQL?", "expected_answer": "Run VACUUM. Standard VACUUM marks dead row space reusable; VACUUM FULL actively compacts the table and returns space to the OS but takes an exclusive lock.", "qtype": "vocab-mismatch", "gold": [{"doc_id": "postgres/routine-vacuuming", "locator": "space it occupies must then be reclaimed for reuse", "grade": "primary"}, {"doc_id": "postgres/routine-vacuuming", "locator": "actively compacts tables by writing a complete new version", "grade": "supporting"}], "notes": "Vocab: user says 'growing on disk'/'reclaim', doc says VACUUM/dead rows."}
{"qid": "q018", "question": "What is the practical difference between standard VACUUM and VACUUM FULL, and when should I avoid the latter?", "expected_answer": "Standard VACUUM runs concurrently and marks space reusable but doesn't return it to the OS; VACUUM FULL rewrites the whole table to reclaim space but needs an ACCESS EXCLUSIVE lock. Avoid VACUUM FULL on live/heavily-used tables.", "qtype": "multi-hop", "gold": [{"doc_id": "postgres/routine-vacuuming", "locator": "it will not return the space to the operating system", "grade": "primary"}, {"doc_id": "postgres/routine-vacuuming", "locator": "requires an `ACCESS EXCLUSIVE` lock", "grade": "primary"}]}
{"qid": "q019", "question": "Why doesn't PostgreSQL immediately remove the old version of a row when I UPDATE or DELETE it?", "expected_answer": "Because of MVCC: the old row version must remain while it's still potentially visible to other transactions, so it's cleaned up later by VACUUM.", "qtype": "factoid", "gold": [{"doc_id": "postgres/routine-vacuuming", "locator": "must not be deleted while it is still potentially visible", "grade": "primary"}]}
{"qid": "q020", "question": "How do I create an index that only covers a subset of rows in a PostgreSQL table?", "expected_answer": "Use a partial index: add a WHERE clause to CREATE INDEX so only rows matching the predicate are indexed.", "qtype": "how-to", "gold": [{"doc_id": "postgres/indexes-partial", "locator": "index built over a subset of a table", "grade": "primary"}]}
{"qid": "q021", "question": "What normalization flag makes ts_rank_cd divide the rank by the document length in PostgreSQL full-text search?", "expected_answer": "Normalization option 1 (and 2 for log/unique-word variants) divides the rank by document length; option 32 divides rank by itself plus one. Length normalization is bit 1.", "qtype": "factoid", "gold": [{"doc_id": "postgres/textsearch-controls", "locator": "divides the rank by the document length", "grade": "primary"}], "notes": "Exact-identifier: ts_rank_cd + normalization integer. Now works post-hygiene fix."}
{"qid": "q022", "question": "How do I keep PostgreSQL full-text search fast on a large table of documents?", "expected_answer": "Create a GIN index on the tsvector (optionally a stored generated tsvector column) so searches use the index instead of scanning.", "qtype": "how-to", "gold": [{"doc_id": "postgres/textsearch-tables", "locator": "create a GIN index", "grade": "primary"}]}
{"qid": "q023", "question": "The PostgreSQL planner keeps choosing a sequential scan instead of my index. How can I see what plan it picked and why?", "expected_answer": "Use EXPLAIN (or EXPLAIN ANALYZE) to see the chosen plan and estimated/actual costs; the planner picks seq scan when it estimates that's cheaper.", "qtype": "vocab-mismatch", "gold": [{"doc_id": "postgres/using-explain", "locator": "Using `EXPLAIN`", "grade": "primary"}]}
{"qid": "q024", "question": "What isolation level does a PostgreSQL transaction use by default?", "expected_answer": "Read Committed is the default isolation level in PostgreSQL.", "qtype": "factoid", "gold": [{"doc_id": "postgres/transaction-iso", "locator": "is the default isolation level in PostgreSQL", "grade": "primary"}]}
{"qid": "q025", "question": "How do I speed up a bulk data load of many rows into PostgreSQL?", "expected_answer": "Use COPY instead of INSERT, and consider dropping/recreating indexes, increasing maintenance_work_mem, and disabling autocommit around the load.", "qtype": "how-to", "gold": [{"doc_id": "postgres/populate", "locator": "Use `COPY`", "grade": "primary"}]}
{"qid": "q026", "question": "What is the purpose of the write-ahead log (WAL) in PostgreSQL?", "expected_answer": "WAL logs changes before they're applied to data files so committed changes survive a crash; it also enables replication and point-in-time recovery.", "qtype": "factoid", "gold": [{"doc_id": "postgres/wal-intro", "locator": "changes to data files", "grade": "primary"}]}
{"qid": "q027", "question": "When would a BRIN index be a better choice than a B-tree in PostgreSQL?", "expected_answer": "BRIN suits very large tables where rows are naturally ordered by the indexed column (e.g. timestamps); it stores per-block-range summaries, so it's tiny and cheap but less precise than a B-tree.", "qtype": "factoid", "gold": [{"doc_id": "postgres/indexes-types", "locator": "BRIN", "grade": "primary"}]}
{"qid": "q031", "question": "How do I limit which HTTP origins can call my FastAPI app from a browser?", "expected_answer": "Add CORSMiddleware with allow_origins set to the permitted origins.", "qtype": "how-to", "gold": [{"doc_id": "fastapi/tutorial/cors", "locator": "CORSMiddleware", "grade": "primary"}]}
{"qid": "q032", "question": "In FastAPI, how do I run a slow piece of work after the response has already been sent to the client?", "expected_answer": "Use BackgroundTasks: declare a BackgroundTasks parameter and add tasks to it; they run after the response is returned.", "qtype": "vocab-mismatch", "gold": [{"doc_id": "fastapi/tutorial/background-tasks", "locator": "BackgroundTasks", "grade": "primary"}]}
{"qid": "q033", "question": "How do I share common logic like a database session across many FastAPI endpoints without repeating it?", "expected_answer": "Use dependency injection: define a dependency function and inject it with Depends() in each path operation.", "qtype": "vocab-mismatch", "gold": [{"doc_id": "fastapi/tutorial/dependencies/index", "locator": "Depends", "grade": "primary"}]}
{"qid": "q034", "question": "How do I write tests for a FastAPI application?", "expected_answer": "Use TestClient (based on httpx/Starlette): instantiate TestClient(app) and call it like a requests client inside normal test functions.", "qtype": "how-to", "gold": [{"doc_id": "fastapi/tutorial/testing", "locator": "TestClient", "grade": "primary"}]}
{"qid": "q035", "question": "How can I replace a dependency with a fake while testing a FastAPI endpoint that also uses an async database session?", "expected_answer": "Use app.dependency_overrides to swap the dependency for a test double; combine with async test support (httpx AsyncClient / anyio) for async sessions.", "qtype": "multi-hop", "gold": [{"doc_id": "fastapi/advanced/testing-dependencies", "locator": "dependency_overrides", "grade": "primary"}, {"doc_id": "fastapi/advanced/async-tests", "locator": "AsyncClient", "grade": "supporting"}], "notes": "Multi-hop: override mechanism in one doc, async testing in another."}
{"qid": "q036", "question": "How do I return a specific non-200 HTTP status code from a FastAPI path operation?", "expected_answer": "Pass status_code to the path operation decorator (e.g. @app.post(..., status_code=201)), optionally using the fastapi.status constants.", "qtype": "how-to", "gold": [{"doc_id": "fastapi/tutorial/response-status-code", "locator": "status_code", "grade": "primary"}]}
{"qid": "q037", "question": "In FastAPI, how do I read configuration from environment variables in a typed, validated way?", "expected_answer": "Use a Pydantic Settings (pydantic-settings) BaseSettings class; fields are read from environment variables and validated.", "qtype": "how-to", "gold": [{"doc_id": "fastapi/advanced/settings", "locator": "BaseSettings", "grade": "primary"}]}
{"qid": "q038", "question": "What two standard transport mechanisms does the MCP specification define?", "expected_answer": "stdio (over standard in/out) and Streamable HTTP.", "qtype": "factoid", "gold": [{"doc_id": "mcp/specification/2025-06-18/basic/transports", "locator": "two standard transport mechanisms", "grade": "primary"}]}
{"qid": "q039", "question": "What message-encoding format does MCP use on the wire?", "expected_answer": "JSON-RPC 2.0. All MCP messages are encoded as JSON-RPC.", "qtype": "factoid", "gold": [{"doc_id": "mcp/specification/2025-06-18/basic/transports", "locator": "JSON-RPC", "grade": "primary"}]}
{"qid": "q040", "question": "Which JSON-RPC method does an MCP client send to discover the tools a server offers?", "expected_answer": "tools/list. The client sends a tools/list request to enumerate available tools.", "qtype": "factoid", "gold": [{"doc_id": "mcp/specification/2025-06-18/server/tools", "locator": "clients send a `tools/list` request", "grade": "primary"}]}
{"qid": "q041", "question": "How does an MCP client actually invoke a specific tool on the server?", "expected_answer": "By sending a tools/call request with the tool name and arguments.", "qtype": "how-to", "gold": [{"doc_id": "mcp/specification/2025-06-18/server/tools", "locator": "clients send a `tools/call` request", "grade": "primary"}]}
{"qid": "q042", "question": "In MCP, how does a server tell a client that the list of available tools has changed?", "expected_answer": "By emitting a list-changed notification (notifications/tools/list_changed), which the server must declare support for via the listChanged capability.", "qtype": "how-to", "gold": [{"doc_id": "mcp/specification/2025-06-18/server/tools", "locator": "listChanged", "grade": "primary"}]}
{"qid": "q043", "question": "What is the first request an MCP client sends when establishing a connection, and what is it for?", "expected_answer": "An initialize request, which negotiates protocol version and exchanges capabilities before normal operation.", "qtype": "factoid", "gold": [{"doc_id": "mcp/specification/2025-06-18/basic/lifecycle", "locator": "initialize", "grade": "primary"}]}
